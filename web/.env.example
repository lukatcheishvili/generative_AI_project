# Copy this file to .env.local and fill in values:  cp .env.example .env.local
# On Vercel, set these in Project Settings -> Environment Variables instead.

# Which model provider to use:  gemini | vertex
LLM_PROVIDER=gemini

# Model id (optional; same name works on both providers)
GEMINI_MODEL=gemini-2.5-flash

# ---------------------------------------------------------------------------
# Option A — Gemini API  (LLM_PROVIDER=gemini)
# Get a free key at https://aistudio.google.com/apikey
# ---------------------------------------------------------------------------
GEMINI_API_KEY=

# ---------------------------------------------------------------------------
# Option B — Vertex AI  (LLM_PROVIDER=vertex)
# Uses Google Cloud auth, NOT an API key.
# ---------------------------------------------------------------------------
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
# Service-account credentials for Vertex. Either:
#   - paste the raw service-account JSON on a single line, OR
#   - paste a base64 encoding of that JSON (handy for Vercel env vars).
# Locally you can instead run `gcloud auth application-default login` and leave this blank.
GOOGLE_SERVICE_ACCOUNT_JSON=
