# PageForge Python backend — environment.
#
# The backend ALSO reads web/.env.local automatically (the canonical source of
# truth shared with the frontend), so for local dev you usually do NOT need to
# fill this in. Create server/.env only if you want to OVERRIDE those values for
# the Python service specifically. Never commit real secrets.

# Flip between "gemini" and "vertex" to switch backends.
LLM_PROVIDER=vertex
GEMINI_MODEL=gemini-2.5-flash

# --- Vertex AI ---
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=europe-west1
# Service-account JSON, raw OR base64. Leave blank locally to use ADC
# (gcloud auth application-default login).
GOOGLE_SERVICE_ACCOUNT_JSON=

# --- Gemini Developer API (fallback / quick demo) ---
# Get a free key at https://aistudio.google.com/apikey, then set LLM_PROVIDER=gemini
GEMINI_API_KEY=

# Optional: restrict CORS to the frontend origin (defaults to "*").
# FRONTEND_ORIGIN=http://localhost:3000
