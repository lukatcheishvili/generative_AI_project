# Copy this file to .env and fill in your values:  cp .env.example .env

# LLM backend: "openai" | "anthropic" | "mock"
# "mock" runs the whole graph with no API key — great for testing the architecture.
LLM_PROVIDER=mock

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Google / Gemini
GEMINI_API_KEY=AIzaSy...
GEMINI_MODEL=gemini-1.5-pro

# Web Search API
TAVILY_API_KEY=tvly-...

# Google APIs (for Places/Custom Search)
GOOGLE_API_KEY=AIza...
GOOGLE_CSE_ID=... # Custom Search Engine ID
SERPAPI_API_KEY=... # Optional fallback for scraping Google Maps Reviews

# Optional: GitHub token if you script repo operations
GITHUB_TOKEN=
