# Copy this file to .env and fill in your values:  cp .env.example .env

# LLM backend: "openai" | "anthropic" | "mock"
# "mock" runs the whole graph with no API key — great for testing the architecture.
LLM_PROVIDER=mock

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: GitHub token if you script repo operations
GITHUB_TOKEN=
